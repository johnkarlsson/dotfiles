#!/usr/bin/env bash
set -euo pipefail

PANE="$1"
SCROLL=$(mktemp)
trap 'rm -f "$SCROLL"' EXIT

tmux capture-pane -pS - -t "$PANE" > "$SCROLL"

SELECTED=$(
  nl -ba "$SCROLL" |
  fzf --tac --no-sort --exact --query "❯" \
    --nth=2.. \
    --preview="awk -v q={q} 'NR>=({1}-5) && NR<=({1}+30) { if (q != \"\" && index(\$0,q)) printf \"\\033[43;30m%s\\033[0m\\n\", \$0; else print }' \"$SCROLL\"" \
    --preview-window=right:60%:wrap
) || exit 0

LINE_NUM=$(echo "$SELECTED" | awk '{print $1}')
TOTAL=$(wc -l < "$SCROLL")
FROM_BOTTOM=$((TOTAL - LINE_NUM))

tmux copy-mode -t "$PANE"
tmux send-keys -t "$PANE" -X goto-line "$FROM_BOTTOM"
