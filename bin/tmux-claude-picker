#!/usr/bin/env bash
set -euo pipefail

# fzf window picker scoped to panes running Claude Code.
# Uses session_id:window.pane to avoid collisions across sessions.

SESSION="$1"

DIR=$(mktemp -d)
trap 'rm -rf "$DIR"' EXIT

# Map pane PIDs to window.pane — only for the current session
tmux list-panes -s -t "$SESSION" -F '#{pane_pid} #I.#P' > "$DIR/pane_pids.txt"

# Find claude processes and trace each back to its tmux pane
{ pgrep -x claude 2>/dev/null; pgrep -fi 'dbexec.*claude' 2>/dev/null; true; } | sort -u | while read -r cpid; do
    pid=$cpid
    while [ "$pid" -gt 1 ] 2>/dev/null; do
        if match=$(grep "^${pid} " "$DIR/pane_pids.txt" | head -1); then
            wp="${match#* }"   # e.g. 1.2
            win="${wp%.*}"     # e.g. 1
            pane="${wp##*.}"   # e.g. 2
            if ! grep -qx "$pane" "$DIR/${win}.panes" 2>/dev/null; then
                echo "$pane" >> "$DIR/${win}.panes"
                tmux capture-pane -pS - -t "${SESSION}:${wp}" > "$DIR/${wp}.scroll" 2>/dev/null || true
                tmux capture-pane -pS - -e -t "${SESSION}:${wp}" > "$DIR/${wp}.colored" 2>/dev/null || true
            fi
            break
        fi
        pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
        [ -z "$pid" ] && break
    done
done || true

# Window list — only windows with at least one claude pane
tmux list-windows -t "$SESSION" -F '#I #W' | while read -r win name; do
    [ ! -f "$DIR/${win}.panes" ] && continue
    panes=$(while read -r pane; do
        tmux display-message -t "${SESSION}:${win}.${pane}" -p '#{pane_current_command}'
    done < "$DIR/${win}.panes" | paste -sd, - | sed 's/,/, /g')
    echo "$win: $name [$panes]"
done > "$DIR/windows.list"

if [ ! -s "$DIR/windows.list" ]; then
    tmux display-message "No panes running claude"
    exit 0
fi

# --- search helper ---
cat > "$DIR/search.sh" << 'HEREDOC'
#!/usr/bin/env bash
DIR="$1"; Q="$2"
if [ -z "$Q" ]; then
    cat "$DIR/windows.list"
    exit 0
fi
while IFS= read -r line; do
    win="${line%%:*}"
    win="${win// /}"
    # Name match
    if echo "$line" | grep -qi -F -- "$Q" 2>/dev/null; then
        echo "$line" | GREP_COLORS='ms=01;33' grep -i --color=always -F -- "$Q"
        continue
    fi
    # Scrollback match across claude panes
    [ ! -f "$DIR/${win}.panes" ] && continue
    while read -r pane; do
        scroll="$DIR/${win}.${pane}.scroll"
        [ ! -f "$scroll" ] && continue
        if match=$(grep -i -F -- "$Q" "$scroll" | tail -1 | sed 's/^[[:space:]]*//' | cut -c1-50) && [ -n "$match" ]; then
            printf '%s \033[2m│ %s\033[0m\n' "$line" "$match"
            break
        fi
    done < "$DIR/${win}.panes"
done < "$DIR/windows.list"
HEREDOC

# --- preview helper ---
cat > "$DIR/preview.sh" << 'HEREDOC'
#!/usr/bin/env bash
DIR="$1"; ENTRY="$2"; Q="$3"
win="${ENTRY%%:*}"
win="${win// /}"

best_pane=""
if [ -n "$Q" ] && [ -f "$DIR/${win}.panes" ]; then
    while read -r pane; do
        scroll="$DIR/${win}.${pane}.scroll"
        [ ! -f "$scroll" ] && continue
        if grep -qi -F -- "$Q" "$scroll" 2>/dev/null; then
            best_pane="$pane"
            break
        fi
    done < "$DIR/${win}.panes"
fi

if [ -n "$best_pane" ]; then
    # Collect all matching line numbers from the plain text version
    match_lines=$(grep -in -F -- "$Q" "$DIR/${win}.${best_pane}.scroll" | cut -d: -f1 | paste -sd, -)
    last_num=$(echo "$match_lines" | tr ',' '\n' | tail -1)
    colored="$DIR/${win}.${best_pane}.colored"
    if [ -n "$last_num" ] && [ -f "$colored" ]; then
        start=$((last_num - 15))
        [ "$start" -lt 1 ] && start=1
        end=$((last_num + 25))
        awk -v s="$start" -v e="$end" -v ml="$match_lines" '
            BEGIN { split(ml, a, ","); for (i in a) hl[a[i]]=1 }
            NR >= s && NR <= e {
                if (NR in hl) { gsub(/\033\[[0-9;]*m/, ""); printf "\033[43;30m%s\033[0m\n", $0 }
                else print
            }' "$colored"
    fi
else
    first_pane=""
    [ -f "$DIR/${win}.panes" ] && read -r first_pane < "$DIR/${win}.panes"
    colored="$DIR/${win}.${first_pane:-1}.colored"
    [ -f "$colored" ] && tail -30 "$colored"
fi
HEREDOC

# --- match helper: find which pane matched for select-pane ---
cat > "$DIR/match.sh" << 'HEREDOC'
#!/usr/bin/env bash
DIR="$1"; WIN="$2"; Q="$3"
[ -z "$Q" ] && exit 0
[ ! -f "$DIR/${WIN}.panes" ] && exit 0
while read -r pane; do
    scroll="$DIR/${WIN}.${pane}.scroll"
    [ ! -f "$scroll" ] && continue
    if grep -qi -F -- "$Q" "$scroll" 2>/dev/null; then
        echo "$pane"
        exit 0
    fi
done < "$DIR/${WIN}.panes"
HEREDOC

SELECTED=$(
    cat "$DIR/windows.list" |
    fzf --prompt="claude> " \
        --ansi \
        --disabled \
        --print-query \
        --bind "change:reload:bash $DIR/search.sh $DIR {q}" \
        --preview "bash $DIR/preview.sh $DIR {} {q}" \
        --preview-window=up:80%:wrap
) || exit 0

QUERY=$(echo "$SELECTED" | head -1)
ENTRY=$(echo "$SELECTED" | tail -1)
WIN="${ENTRY%%:*}"
WIN="${WIN// /}"

tmux select-window -t "${SESSION}:${WIN}"

if [ -n "$QUERY" ]; then
    PANE=$(bash "$DIR/match.sh" "$DIR" "$WIN" "$QUERY")
    if [ -n "$PANE" ]; then
        tmux select-pane -t "${SESSION}:${WIN}.${PANE}"
    fi
fi
